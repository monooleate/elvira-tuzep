---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const siteUrl = 'https://elviratuzep.hu';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: item.href.startsWith('http') ? item.href : `${siteUrl}${item.href}` } : {}),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 pt-6 pb-2">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-gray-500 dark:text-gray-400">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && (
          <svg class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class:list={[
            "transition-colors",
            index < items.length - 1
              ? "hover:text-primary dark:hover:text-primary-400"
              : "text-gray-700 dark:text-gray-300 font-medium hover:text-primary dark:hover:text-primary-400"
          ]}>
            {item.label}
          </a>
        ) : (
          <span class="text-gray-700 dark:text-gray-300 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
