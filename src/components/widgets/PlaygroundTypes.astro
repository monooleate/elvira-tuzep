---
/**
 * PlaygroundTypes.astro
 * Köztéri vs Magánkerti játszótér típusok
 * Váltakozó színekkel
 */

import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

const {
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const playgroundTypes = [
  {
    type: 'public',
    title: 'Köztéri Játszóterek',
    emoji: '🏛️',
    description: 'Önkormányzatok, iskolák, óvodák, lakóparkok számára tervezett, nagy teherbírású játszóterek.',
    features: [
      'EN 1176 szabványnak megfelelő',
      'Fokozott igénybevételre tervezve',
      'Vandálbiztos kivitel',
      'Professzionális tervezés',
      'Akadálymentesíthető',
    ],
    examples: ['Városi játszóterek', 'Óvoda udvarok', 'Iskolai játszóterek', 'Lakóparki közös terek', 'Camping, üdülő'],
    color: {
      bg: 'bg-blue-50 dark:bg-blue-950/40',
      border: 'border-blue-200 dark:border-blue-800',
      accent: 'bg-blue-500 dark:bg-blue-600',
      text: 'text-blue-700 dark:text-blue-300',
      badge: 'bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300',
    },
  },
  {
    type: 'private',
    title: 'Magánkerti Játszóterek',
    emoji: '🏡',
    description: 'Családi házak kertjébe tervezett, személyre szabott játszóterek a gyerekek örömére.',
    features: [
      'Egyedi méret a kerthez',
      'Barkácsolható kivitel',
      'Költséghatékony megoldás',
      'Bővíthető, módosítható',
      'Értéknövelő beruházás',
    ],
    examples: ['Kerti hinta', 'Kis mászóka', 'Homokozó', 'Játékház', 'Egyensúlyozó gerenda'],
    color: {
      bg: 'bg-pink-50 dark:bg-pink-950/40',
      border: 'border-pink-200 dark:border-pink-800',
      accent: 'bg-pink-500 dark:bg-pink-600',
      text: 'text-pink-700 dark:text-pink-300',
      badge: 'bg-pink-100 dark:bg-pink-900/50 text-pink-700 dark:text-pink-300',
    },
  },
];
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-5xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline
    title="Milyen Játszóteret Tervez?"
    subtitle="Köztéri és magánkerti projektekhez egyaránt szállítunk faanyagot"
    tagline="🎠 Játszótér Típusok"
  />

  <div class="grid md:grid-cols-2 gap-8 mt-8">
    {playgroundTypes.map((type) => (
      <div class={`rounded-2xl p-6 border-2 ${type.color.bg} ${type.color.border} transition-all hover:shadow-lg`}>
        
        <!-- Fejléc -->
        <div class="flex items-center gap-4 mb-4">
          <div class={`w-16 h-16 ${type.color.accent} rounded-xl flex items-center justify-center text-4xl shadow-lg`}>
            {type.emoji}
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
              {type.title}
            </h3>
          </div>
        </div>

        <!-- Leírás -->
        <p class={`mb-4 ${type.color.text}`}>
          {type.description}
        </p>

        <!-- Jellemzők -->
        <div class="mb-4">
          <h4 class="font-semibold text-gray-800 dark:text-gray-200 mb-2">Jellemzők:</h4>
          <ul class="space-y-1">
            {type.features.map((feature) => (
              <li class={`flex items-center gap-2 text-sm ${type.color.text}`}>
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <!-- Példák -->
        <div>
          <h4 class="font-semibold text-gray-800 dark:text-gray-200 mb-2">Például:</h4>
          <div class="flex flex-wrap gap-2">
            {type.examples.map((example) => (
              <span class={`text-xs font-medium px-2 py-1 rounded-full ${type.color.badge}`}>
                {example}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Közös pont -->
  <div class="mt-8 bg-gradient-to-r from-green-100 to-emerald-100 dark:from-green-900/30 dark:to-emerald-900/30 rounded-xl p-6 border border-green-200 dark:border-green-800">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div>
        <h4 class="font-bold text-green-800 dark:text-green-200 text-lg">
          Közös pont: Gyermekbiztonság!
        </h4>
        <p class="text-green-700 dark:text-green-300">
          Mindkét típushoz <strong>ugyanazt a biztonságos, Tanalith-kezelt faanyagot</strong> ajánljuk – EN 71 tanúsítvánnyal, nehézfém-mentesen.
        </p>
      </div>
    </div>
  </div>
</WidgetWrapper>
