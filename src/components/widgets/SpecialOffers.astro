---
import ProductCard from '~/components/widgets/ProductCard';
import { getDiscountBadge, fetchDiscountedProducts } from '~/lib/discounts';


// Akciós termékek lekérése
const discounted = fetchDiscountedProducts(20);

// Szűrés: csak érvényes akciók
const activeDiscounted = discounted.filter((p: any) => {
  if (!p) return false;
  return getDiscountBadge(p).hasDiscount;
});

const count = activeDiscounted.length;
---

{count > 0 && (
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-10 text-center">
        Akciós termékeink
      </h2>

      {/* 🔹 1–3 TERMÉK: klasszikus grid */}
      {count <= 3 && (
        <div
          class={`grid gap-6 mx-auto ${
            count === 1
              ? 'max-w-[400px] grid-cols-1'
              : count === 2
              ? 'max-w-3xl grid-cols-1 sm:grid-cols-2'
              : 'max-w-6xl grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'
          }`}
        >
          {activeDiscounted.map((product) => (
            <ProductCard product={product} client:load />
          ))}
        </div>
      )}

      {/* 🔹 4+ TERMÉK: horizontális scroll */}
      {count > 3 && (
        <div class="relative">
          <div class="overflow-x-auto scroll-smooth scrollbar-hide">
            <div class="flex gap-6 pb-4">
              {activeDiscounted.map((product) => (
                <div class="flex-none w-[280px] sm:w-[320px]">
                  <ProductCard product={product} client:load />
                </div>
              ))}
            </div>
          </div>

        </div>
      )}
    </div>
  </section>
)}
