---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';
import Breadcrumbs from '~/components/common/Breadcrumbs.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';
import type { BreadcrumbItem } from '~/components/common/Breadcrumbs.astro';

export interface Props {
  metadata?: MetaData;
  breadcrumb?: BreadcrumbItem[];
}

const { metadata, breadcrumb } = Astro.props;

const siteUrl = 'https://elviratuzep.hu';

const breadcrumbSchema = breadcrumb ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((bc, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: bc.label,
    ...(bc.href ? { item: bc.href.startsWith('http') ? bc.href : `${siteUrl}${bc.href}` } : {}),
  })),
} : null;
---

<Layout metadata={metadata}>
  <slot name="head" slot="head" />
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  )}
  <slot name="announcement">
    <Announcement />
  </slot>
  <slot name="header">
    <Header {...headerData} isSticky showToggleTheme />
  </slot>
  <main>
    {breadcrumb && <Breadcrumbs items={breadcrumb} />}
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
