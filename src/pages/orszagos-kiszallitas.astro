---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import DeliveryZones from '~/components/widgets/DeliveryZones.astro';
import WhatToDeliver from '~/components/widgets/WhatToDeliver.astro';

const metadata = {
  title: 'Országos Kiszállítás | Telített Fa & Brikett | Elvira Tüzép',
  description: 'Országos házhozszállítás raklapos tételben! Telített kertifa, brikett bruttó 23.000 Ft-tól. 3 napos kiszállítás, expressz opció. Rendeljen most!',
  canonical: 'https://elviratuzep.hu/orszagos-kiszallitas',
  openGraph: {
    type: 'website',
    title: 'Országos Kiszállítás - Telített Fa & Brikett | Elvira Tüzép',
    description: 'Raklapos házhozszállítás országosan! 3 nap alatt nálad. Telített kertifa, tűzifa brikett.',
    image: '~/assets/images/og-orszagos-kiszallitas.jpg',
  },
};
---

<Layout metadata={metadata}>
  
  <!-- ============================================
       1. HERO SECTION
       ============================================ -->
  <Hero
    id="hero"
    tagline="🚚 Országos Házhozszállítás"
    title="Harmadnapra Nálad a Raklap!"
    actions={[
      {
        variant: 'primary',
        text: 'Árajánlat kérése',
        href: '/kapcsolat',
        icon: 'tabler:mail',
      },
      {
        variant: 'secondary',
        text: 'Mit szállítunk?',
        href: '#mit-szallitsunk',
        icon: 'tabler:package',
      },
    ]}
  >
    <Fragment slot="subtitle">
      <div class="space-y-3">
        <p class="text-xl md:text-2xl font-medium text-gray-700 dark:text-gray-200">
          <span class="text-primary-600 dark:text-primary-400 font-bold">Telített kertifa</span>, 
          <span class="text-amber-600 dark:text-amber-400 font-bold">Brikett</span> és 
          <span class="text-indigo-600 dark:text-indigo-400 font-bold">még sok minden más</span> – 
          raklapon, az ország bármely pontjára!
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4 pt-4 pb-4">
          <div class="inline-flex items-center gap-2 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Bruttó ~23.000 Ft-tól</span>
          </div>
          
          <div class="inline-flex items-center gap-2 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>3 napos szállítás</span>
          </div>
          
          <div class="inline-flex items-center gap-2 bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <span>Expressz opció</span>
          </div>
        </div>
      </div>
    </Fragment>

