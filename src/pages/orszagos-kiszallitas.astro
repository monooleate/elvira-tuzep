  </Hero>

  <!-- ============================================
       2. MOTIVÁCIÓS SZEKCIÓ
       ============================================ -->
  <section class="py-12 md:py-16 bg-gradient-to-r from-emerald-50 via-white to-amber-50 dark:from-slate-900 dark:via-emerald-950/30 dark:to-slate-900">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-6">
        Ne legyen álmainak gátja a beszerzés! 🌟
      </h2>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
        Építsen <strong class="text-emerald-600 dark:text-emerald-400">kerítést</strong>, 
        <strong class="text-emerald-600 dark:text-emerald-400">kertet</strong>, 
        <strong class="text-emerald-600 dark:text-emerald-400">gyermekjátszóteret</strong>. 
        <br class="hidden md:block" />
        <span class="text-amber-600 dark:text-amber-400 font-semibold">Nyűgözza le a szomszédokat!</span> 
        <br class="hidden md:block" />
        A termékeket mi adjuk – Ön csak megrendeli, és <strong>harmadnapra ott a raklap</strong>.
      </p>
    </div>
  </section>

  <!-- ============================================
       3. SZÁLLÍTÁSI INFORMÁCIÓ
       ============================================ -->
  <DeliveryZones id="szallitas" />

  <!-- ============================================
       4. MIT CÉLSZERŰ KISZÁLLÍTTATNI?
       ============================================ -->
  <WhatToDeliver id="mit-szallitsunk" />

  <!-- ============================================
       5. MIÉRT TŐLÜNK RENDELJEN?
       ============================================ -->
  <Features
    id="elonyok"
    title="Miért Tőlünk Rendeljen?"
    subtitle="Országos házhozszállítás, megbízható minőség, egyszerű rendelés"
    columns={3}
    items={[
      {
        title: 'Országos Kiszállítás',
        description: 'Az ország bármely pontjára szállítunk raklapos tételben. Budapesttől Debrecenig, Soprontól Szegedig – mindenhova!',
        icon: 'tabler:map-pin',
      },
      {
        title: '3 Napos Szállítás',
        description: 'Megrendelés után 3 munkanapon belül kézbesítjük. Sürgős? Expressz opcióval még gyorsabban!',
        icon: 'tabler:truck-delivery',
      },
      {
        title: 'Transzparens Árazás',
        description: 'Súly- és távolságfüggő szállítási díjak, nincsenek rejtett költségek. Előre tudja, mire számítson.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Minőségi Termékek',
        description: 'Tanalith-kezelt telített fa, prémium brikett. Csak olyan terméket szállítunk, amit magunknak is megvennénk.',
        icon: 'tabler:award',
      },
      {
        title: 'Rugalmas Mennyiség',
        description: 'Brikettnél akár kisebb tételben is. Telített fánál raklapos minimum – a legjobb ár-érték arány.',
        icon: 'tabler:packages',
      },
      {
        title: '15+ Év Tapasztalat',
        description: 'Megbízható partner vagyunk. Több ezer elégedett vásárló szerte az országban.',
        icon: 'tabler:history',
      },
    ]}
  />

