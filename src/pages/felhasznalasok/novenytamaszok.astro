    items={[
      { title: '1. Válassza ki a megfelelő méretet', description: 'Lásd a mérettáblázatot fent. Szőlőhöz: Ø4-5 cm, 200-250 cm. Paradicsomhoz: Ø3-4 cm, 100-150 cm.', icon: 'tabler:ruler-measure' },
      { title: '2. Jelölje ki a karók helyét', description: 'Használjon kifeszített zsinórt az egyenes sorvezetéshez. Jelölje meg minden pozíciót. Szőlőnél: 4-6 m karótávolság.', icon: 'tabler:map-pin' },
      { title: '3. Verje le a karókat', description: 'A hegyezett végüket verje a földbe 50-60 cm mélyre. Használjon fa kalapácsot vagy cölöpverőt. Kemény talajnál előfúrás.', icon: 'tabler:hammer' },
      { title: '4. Ellenőrizze a függőlegességet', description: 'Használjon függőónt vagy vízmértéket. A ferde karó nem tartja megfelelően a növényt.', icon: 'tabler:arrows-vertical' },
      { title: '5. Kösse fel a növényeket', description: 'Rögzítse puha zsinórral, speciális szalaggal vagy rugalmas kötözővel. Ne szorítsa túl – a növénynek helye kell a növekedéshez.', icon: 'tabler:link' },
      { title: '6. Feszítse ki a huzalt (szőlőhöz)', description: 'Spalérrendszerhez 2-3 sor horganyzott huzalt feszítsen a karók közé. Rögzítse szegekkel vagy kapcsokkal.', icon: 'tabler:line-height' },
