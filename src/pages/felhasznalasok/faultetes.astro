---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductSizes from '~/components/widgets/ProductSizes.astro';

const metadata = {
  title: 'Faültetéshez Tartó Cölöp | Telített Fa | Elvira Tüzép',
  description: 'Telített fa cölöpök faültetéshez. Hegyezett borovi cölöpök 15-25 év élettartammal. Szőlőkaró, gyümölcsfa támasz.',
  canonical: 'https://elviratuzep.hu/felhasznalasok/faultetes',
  openGraph: {
    type: 'website',
    title: 'Faültetéshez Tartó Cölöp - Telített Fa | Elvira Tüzép',
    description: 'Tartós, telített fa cölöpök faültetéshez. Nem rohad, nem korhad, 15-25 évig bírja a földben.',
    image: '~/assets/images/og-faultetes.jpg',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Melyik végével kell lefelé verni a cölöpöt?', acceptedAnswer: { '@type': 'Answer', text: 'A hegyezett végével lefelé – ez megkönnyíti a beverést. Ha nagyon kemény a talaj, előfúrás segíthet.' } },
    { '@type': 'Question', name: 'Hány cölöp kell egy fához?', acceptedAnswer: { '@type': 'Answer', text: 'Kisebb csemetéhez 1-2 cölöp elegendő. Nagyobb fákhoz (3+ méter) 2-3 cölöp ajánlott háromszög alakban a nagyobb stabilitásért.' } },
    { '@type': 'Question', name: 'Milyen mélyre kell verni?', acceptedAnswer: { '@type': 'Answer', text: 'A cölöp hosszának kb. 1/3-át (min. 50-60 cm) kell a földbe verni a stabil álláshoz.' } },
    { '@type': 'Question', name: 'Meddig kell a fát támasztani?', acceptedAnswer: { '@type': 'Answer', text: 'Általában 2-3 évig, amíg a gyökérzet meg nem erősödik. Túl sokáig hagyva a fa "elkényelmesedik".' } },
    { '@type': 'Question', name: 'Mivel kössem a fát a cölöphöz?', acceptedAnswer: { '@type': 'Answer', text: 'Puha fakötöző szalaggal, kókuszszalaggal vagy speciális fa-rögzítővel. Drót és műanyag zsineg sértheti a kérget!' } },
    { '@type': 'Question', name: 'Használhatom szőlőhöz is?', acceptedAnswer: { '@type': 'Answer', text: 'Igen! A telített cölöpök kiválóan alkalmasak szőlőkarónak is – évtizedekig bírják a terhelést.' } },
    { '@type': 'Question', name: 'Festhetem a telített fát?', acceptedAnswer: { '@type': 'Answer', text: 'Igen, de várjon 3-6 hónapot a telítés után, amíg a fa kiszárad. Használjon nem vizes bázisú festéket vagy lazúrt.' } },
    { '@type': 'Question', name: 'Mi a különbség a mártott és a telített között?', acceptedAnswer: { '@type': 'Answer', text: 'A mártott fa csak felületileg védett (2-3 év), a telített fa mélyen átitatott (15-25 év). Földbe csak telített cölöpöt tegyen!' } },
  ],
};
---

<Layout metadata={metadata} breadcrumb={[
  { label: 'Főoldal', href: '/' },
  { label: 'Telített fa', href: '/telifa' },
  { label: 'Faültetés' },
]}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <!-- ============================================
       1. HERO SECTION
       ============================================ -->
  <Hero
    id="hero"
    tagline="🌳 Faültetéshez"
    title="Tartó Cölöpök – Hogy a Fa Egyenesen Nőjön"
    actions={[
      {
        variant: 'primary',
        text: 'Árajánlat kérése',
        href: '/kapcsolat',
        icon: 'tabler:mail',
      },
      {
        variant: 'secondary',
        text: 'Méretek & Árak',
        href: '#product-sizes',
        icon: 'tabler:ruler',
      },
    ]}
  >
    <Fragment slot="subtitle">
      <div class="space-y-3">
        <p class="text-xl md:text-2xl font-medium text-gray-700 dark:text-gray-200">
          <span class="text-emerald-600 dark:text-emerald-400 font-bold">Telített, hegyezett cölöpök</span> 
          facsemeték, gyümölcsfák és díszfák biztonságos megtámasztásához.
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-4 pt-4 pb-4">
          <div class="inline-flex items-center gap-2 bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>15-25 év élettartam</span>
          </div>
          
          <div class="inline-flex items-center gap-2 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Hegyezett vég</span>
          </div>
          
          <div class="inline-flex items-center gap-2 bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 px-4 py-2 rounded-full font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span>Körmart kivitel</span>
          </div>
        </div>
      </div>
    </Fragment>

    <Fragment slot="image">
      <!-- 
        🖼️ AJÁNLOTT KÉP: 
        - Frissen ültetett fa cölöpökkel megtámasztva
        - Vagy: telített cölöpök raklapon (termékfotó)
        - Forrás: saját fotó vagy Unsplash "tree planting stake"
      -->
<!--       <div class="relative rounded-2xl overflow-hidden shadow-2xl bg-gradient-to-br from-emerald-700 via-green-600 to-lime-600 aspect-[4/3] flex items-center justify-center">
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="relative z-10 text-center text-white p-8">
          <div class="text-8xl mb-4">🌳</div>
          <p class="text-xl font-bold uppercase tracking-wider">Tartó Cölöpök</p>
          <p class="text-lg opacity-80">Faültetéshez</p>
          <p class="text-sm mt-4 bg-white/20 rounded-lg px-4 py-2">
            📸 Ide jön a termékfotó
          </p>
        </div>
        
        <div class="absolute top-4 right-4 bg-emerald-500 text-white px-4 py-2 rounded-lg font-bold text-sm shadow-lg">
          UC4 minősítés
        </div>
      </div> -->
    </Fragment>
  </Hero>

  <!-- ============================================
       2. PROBLÉMA & MEGOLDÁS
       ============================================ -->
  <section class="py-12 md:py-16 bg-gradient-to-r from-red-50 via-white to-emerald-50 dark:from-slate-900 dark:via-slate-800 dark:to-emerald-950/20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        
        <!-- Probléma -->
        <div class="bg-red-50 dark:bg-red-950/30 rounded-2xl p-6 border-2 border-red-200 dark:border-red-800">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-red-500 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-red-800 dark:text-red-200">A Probléma</h2>
          </div>
          <ul class="space-y-3 text-red-700 dark:text-red-300">
            <li class="flex items-start gap-2">
              <span class="text-red-500 mt-1">✗</span>
              <span>Kezeletlen cölöp 2-3 év alatt elrothad</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-500 mt-1">✗</span>
              <span>Mártott fa csak felületileg védett</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-500 mt-1">✗</span>
              <span>Évente cserélgetni kell – drága és macerás</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-500 mt-1">✗</span>
              <span>Elkorhadt cölöp nem támasztja a fát</span>
            </li>
          </ul>
        </div>

        <!-- Megoldás -->
        <div class="bg-emerald-50 dark:bg-emerald-950/30 rounded-2xl p-6 border-2 border-emerald-200 dark:border-emerald-800">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-emerald-500 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-emerald-800 dark:text-emerald-200">A Megoldás</h2>
          </div>
          <ul class="space-y-3 text-emerald-700 dark:text-emerald-300">
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 mt-1">✓</span>
              <span><strong>Telített cölöp 15-25 évig</strong> bírja földben</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 mt-1">✓</span>
              <span>Nagynyomásos kezelés – <strong>mélyen véd</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 mt-1">✓</span>
              <span>Egyszer megveszed, <strong>évtizedekig használod</strong></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 mt-1">✓</span>
              <span>Stabil támasz a fa teljes életében</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       3. FELHASZNÁLÁSI TERÜLETEK
       ============================================ -->
  <Features
    id="felhasznalasok"
    title="Mire Használható?"
    subtitle="A telített tartó cölöp sokoldalú segítség a kertben"
    columns={3}
    items={[
      {
        title: 'Gyümölcsfák Ültetése',
        description: 'Almafa, körtefa, cseresznyefa, szilvafa – minden gyümölcsfa hálás a stabil támaszért az első években. A cölöp megvédi a csemetét a széltől és segít az egyenes törzsformálódásban.',
        icon: 'tabler:apple',
      },
      {
        title: 'Díszfák Megtámasztása',
        description: 'Juhar, hárs, platán, nyírfa – a díszfák egyenes növekedéséhez elengedhetetlen a cölöp. Különösen fontos szeles, kitett területeken.',
        icon: 'tabler:tree',
      },
      {
        title: 'Facsemete Védelem',
        description: 'Fiatal csemeték védelmére a széltől, vadaktól. Stabil rögzítés az első kritikus években, amíg a gyökérzet meg nem erősödik.',
        icon: 'tabler:plant',
      },
      {
        title: 'Szőlőkaró',
        description: 'Szőlőműveléshez tartós karók, amik évtizedekig bírják a terhelést és az időjárást. Telített szőlőkaróból nem kell évente cserélni.',
        icon: 'tabler:line-height',
      },
      {
        title: 'Futónövény Támasz',
        description: 'Borostyán, vadszőlő, rózsák – minden kúszónövény örül a stabil támasznak. A telített fa támasz földben is tartós marad.',
        icon: 'tabler:plant-2',
      },
      {
        title: 'Sövény Rögzítés',
        description: 'Frissen ültetett sövények egyenes sorba rendezéséhez és rögzítéséhez. Ideális tuja, babérmeggy és buxus sövényekhez.',
        icon: 'tabler:line-height',
      },
    ]}
  />

  <!-- ============================================
       4. MÉRET TÁBLÁZAT / TERMÉKEK
       ============================================ -->
  <ProductSizes id="product-sizes" />

  <!-- ============================================
       5. HOGYAN VÁLASSZON? - Segédlet
       ============================================ -->
  <Content
    id="hogyan-valasszon"
    isReversed
    title="Hogyan Válasszon Cölöpöt?"
    subtitle="Egyszerű szabályok a megfelelő méret kiválasztásához"
    items={[
      {
        title: 'Átmérő szabály',
        description: 'A cölöp átmérője legyen legalább 1/3-a a fa törzsének. Vékony csemetéhez 4-5 cm, nagyobb fához 6-10 cm.',
      },
      {
        title: 'Hosszúság szabály',
        description: 'A cölöp 1/3-a legyen a földben, 2/3-a felette. 2 méteres cölöpnél ~65 cm földben, ~135 cm kint.',
      },
      {
        title: 'Darabszám',
        description: 'Kisebb fához 1-2 cölöp, nagyobb fához 2-3 cölöp háromszög alakban a stabilitásért.',
      },
    ]}
    callToAction={{
      text: 'Kérdése van? Írjon! →',
      href: '/kapcsolat',
    }}
    classes={{
      container: 'bg-blue-50 dark:bg-blue-950/30',
    }}
  >
    <Fragment slot="content">
      <div class="bg-blue-100 dark:bg-blue-900/40 rounded-xl p-6 border-l-4 border-blue-500">
        <h3 class="text-xl font-bold text-blue-800 dark:text-blue-200 mb-3">
          📏 Gyors Méretező
        </h3>
        <div class="space-y-2 text-blue-700 dark:text-blue-300 text-sm">
          <p><strong>Facsemete (1-2 m):</strong> 4x150 vagy 4x200 cm cölöp</p>
          <p><strong>Fiatal fa (2-3 m):</strong> 5x200 vagy 6x200 cm cölöp</p>
          <p><strong>Nagyobb fa (3-5 m):</strong> 6x250 vagy 8x250 cm cölöp</p>
          <p><strong>Nagy fa (5+ m):</strong> 8x300 vagy 10x300 cm cölöp</p>
        </div>
      </div>
    </Fragment>

    <Fragment slot="image">
   
      <img
        src="/images/faultetes-500.avif"
        alt="4 cölöppel rögzített fiatal facsemete képe"
        class="w-full rounded-lg shadow-lg"
      />

    </Fragment>
  </Content>

  <!-- ============================================
       6. ÜLTETÉSI TIPPEK (Steps)
       ============================================ -->
  <Steps
    id="ultetes-tippek"
    title="Faültetés Lépésről Lépésre"
    subtitle="Így használja a tartó cölöpöket szakszerűen"
    items={[
      {
        title: '1. Készítse elő a gödröt',
        description: 'Ásson akkora gödröt, ami kétszer szélesebb a gyökérzetnél. A cölöpöket még a fa behelyezése ELŐTT verje le.',
        icon: 'tabler:shovel',
      },
      {
        title: '2. Verje le a cölöpöket',
        description: 'A cölöpöket a gödör szélére, a törzstől 10-15 cm távolságra verje. Legalább 50-60 cm mélyen legyen a földben.',
        icon: 'tabler:hammer',
      },
      {
        title: '3. Ültesse el a fát',
        description: 'Helyezze a fát a gödörbe, töltse fel földdel, tapossa meg. A gyökérnyak maradjon a talajszinten.',
        icon: 'tabler:plant',
      },
      {
        title: '4. Rögzítse a törzset',
        description: 'Puha fakötöző szalaggal vagy kókuszszalaggal rögzítse a törzset a cölöpökhöz. Ne feszítse túl!',
        icon: 'tabler:link',
      },
      {
        title: '5. Öntözés és mulcsolás',
        description: 'Alaposan öntözze meg, majd mulcsolja a tövét. A támasztékot 2-3 év után távolítsa el.',
        icon: 'tabler:droplet',
      },
    ]}
  />

  <!-- ============================================
       7. MIÉRT TELÍTETT FA?
       ============================================ -->
  <Content
    id="miert-telitett"
    title="Miért Telített Fa Cölöpöt Válasszon?"
    subtitle="A nagynyomásos kezelés előnyei"
    items={[
      {
        title: 'Mély védelem',
        description: 'A Tanalith favédőszer mélyen behatol a fa rostjaiba, nem csak a felületet védi.',
      },
      {
        title: 'UC4 minősítés',
        description: 'Talajkontaktusban és állandó nedvességben is használható – pont oda, ahova a cölöp kerül.',
      },
      {
        title: 'Nem kell cserélgetni',
        description: 'Egyszer megveszi, 15-25 évig használja. Hosszú távon sokkal olcsóbb, mint évente új kezeletlen cölöpöt venni.',
      },
    ]}
    callToAction={{
      text: 'Telített fa részletesen →',
      href: '/telitett-fa',
    }}
    classes={{
      container: 'bg-emerald-50 dark:bg-emerald-950/30',
    }}
  >
    <Fragment slot="content">
      <div class="bg-emerald-100 dark:bg-emerald-900/40 rounded-xl p-6 border-l-4 border-emerald-500">
        <h3 class="text-xl font-bold text-emerald-800 dark:text-emerald-200 mb-3">
          🛡️ Tanalith Kezelés
        </h3>
        <ul class="space-y-2 text-emerald-700 dark:text-emerald-300">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Nehézfém-mentes (nincs króm, arzén)
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Környezetbarát, nem szennyezi a talajt
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Rovarok, gombák, korhadás ellen véd
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Fémmel nem korrodál
          </li>
        </ul>
      </div>
    </Fragment>

    <Fragment slot="image">
      <img
        src="/images/pressure_treated_timber-500.avif"
        alt="Tanalith-tal kezelt fa metszeti képe"
        class="w-full rounded-lg shadow-lg"
      />
    </Fragment>
  </Content>

  <!-- ============================================
       8. GYIK
       ============================================ -->
  <FAQs
    id="gyik"
    title="Gyakran Ismételt Kérdések"
    subtitle="Minden, amit a tartó cölöpökről tudni érdemes"
    items={[
      {
        title: 'Melyik végével kell lefelé verni a cölöpöt?',
        description: 'A hegyezett végével lefelé – ez megkönnyíti a beverést. Ha nagyon kemény a talaj, előfúrás segíthet.',
      },
      {
        title: 'Hány cölöp kell egy fához?',
        description: 'Kisebb csemetéhez 1-2 cölöp elegendő. Nagyobb fákhoz (3+ méter) 2-3 cölöp ajánlott háromszög alakban a nagyobb stabilitásért.',
      },
      {
        title: 'Milyen mélyre kell verni?',
        description: 'A cölöp hosszának kb. 1/3-át (min. 50-60 cm) kell a földbe verni a stabil álláshoz.',
      },
      {
        title: 'Meddig kell a fát támasztani?',
        description: 'Általában 2-3 évig, amíg a gyökérzet meg nem erősödik. Túl sokáig hagyva a fa "elkényelmesedik".',
      },
      {
        title: 'Mivel kössem a fát a cölöphöz?',
        description: 'Puha fakötöző szalaggal, kókuszszalaggal vagy speciális fa-rögzítővel. Drót és műanyag zsineg sértheti a kérget!',
      },
      {
        title: 'Használhatom szőlőhöz is?',
        description: 'Igen! A telített cölöpök kiválóan alkalmasak szőlőkarónak is – évtizedekig bírják a terhelést.',
      },
      {
        title: 'Festhetem a telített fát?',
