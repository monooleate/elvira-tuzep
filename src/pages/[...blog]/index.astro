---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';

import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';
import type { MetaData } from '~/types';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import BlogSidebar from '~/components/blog/BlogSidebar.astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogPost();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: 'article',
      ...(image
        ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
        : {}),
    },
  },
  { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
) as MetaData;

const calcSchemaHead = post?.calcSchema;

// Auto-generate Article schema for all blog posts
const siteUrl = 'https://elviratuzep.hu';
const articleImageUrl = typeof image === 'string'
  ? (image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`)
  : image?.src
    ? (image.src.startsWith('http') ? image.src : `${siteUrl}${image.src.startsWith('/') ? '' : '/'}${image.src}`)
    : `${siteUrl}/images/default.png`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'headline': post.title,
  'description': post.excerpt || '',
  'image': articleImageUrl,
  'datePublished': post.publishDate ? new Date(post.publishDate).toISOString() : undefined,
  'dateModified': post.updateDate ? new Date(post.updateDate).toISOString() : (post.publishDate ? new Date(post.publishDate).toISOString() : undefined),
  'author': {
    '@type': 'Person',
    'name': post.author || 'Mészáros János',
    'url': siteUrl,
  },
  'publisher': {
    '@type': 'Organization',
    '@id': 'https://gigawood.hu/#organization',
    'name': 'Gigawood Kft.',
    'logo': {
      '@type': 'ImageObject',
      'url': 'https://gigawood.hu/custom/megawood/image/cache/w220h100m00/GigaWood_logo_3_Vasvari_Design.png',
    },
  },
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': typeof url === 'string' ? url : url?.toString(),
  },
  ...(post.category ? { 'articleSection': post.category.title } : {}),
  ...(post.tags?.length ? { 'keywords': post.tags.map((t: any) => typeof t === 'string' ? t : t.title).join(', ') } : {}),
  'inLanguage': 'hu',
};

const blogBreadcrumb = [
  { label: 'Főoldal', href: '/' },
  { label: 'Tudástár', href: '/tudastar' },
  ...(post.category ? [{ label: post.category.title, href: `/tudastar/kategoria/${post.category.slug}` }] : []),
  { label: post.title },
];
---

<Layout metadata={metadata} breadcrumb={blogBreadcrumb}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(articleSchema)}
  />
  {calcSchemaHead && (
    <script
      type="application/ld+json"
      slot="head"
      set:html={calcSchemaHead}
    />
  )}
  <div class="flex flex-col lg:flex-row gap-8 px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <!-- Sidebar bal oldalon (sticky, dark mode kompatibilis, mobilon felül) -->
    <div class="w-full lg:w-1/4 order-first lg:order-none">
      <BlogSidebar />
    </div>
    <!-- Főtartalom jobb oldalon -->
    <section class="w-full lg:w-3/4">
      <SinglePost post={{ ...post, image: image }} url={url}>
        {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
      </SinglePost>
      <ToBlogLink />
      <RelatedPosts post={post} />
    </section>

  </div>
</Layout>