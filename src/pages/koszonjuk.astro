---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Köszönjük! | Elvira Tüzép',
  robots: {
    index: false,
    follow: false,
  },
};
---

<Layout metadata={metadata}>
  <main class="max-w-2xl mx-auto py-16 px-4 text-center">
    <h1 class="text-3xl font-bold">Köszönjük!</h1>
    <p class="mt-4 text-gray-600 dark:text-gray-300">
      Megkaptuk az üzenetet, hamarosan jelentkezünk.
    </p>
    <a href="/" class="inline-block mt-8 text-primary hover:underline">
      Vissza a főoldalra
    </a>
  </main>
</Layout>
