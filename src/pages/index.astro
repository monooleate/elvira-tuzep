      "streetAddress": "Elvira utca 33.",
      "addressLocality": "Érd",
      "addressRegion": "Pest",
      "postalCode": "2030",
      "addressCountry": "HU"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "07:00",
        "closes": "17:00"
      }
    ],
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 47.375516,
      "longitude": 18.932424
    },
    "hasMap": "https://maps.google.com/?q=47.375516,18.932424",
    "parentOrganization": { "@id": "https://gigawood.hu/#organization" },
    "areaServed": ["Érd","Diósd","Tárnok","Budapest","Szigetszentmiklós","Százhalombatta"],
    "currenciesAccepted": "HUF",
    "paymentAccepted": "Cash, Card, BankTransfer",
    "sameAs": [
      "https://www.google.com/maps?cid=4954816018312604745"
    ]
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Mi a különbség a fűrészelt és a gyalult építőfa között?', acceptedAnswer: { '@type': 'Answer', text: 'A fűrészelt építőfa érdes felületű, légszáraz vagy friss állapotban kerül forgalomba, és kedvezőbb árú. A műszárított, gyalult faanyag kamrában szárított, sima felületű és mérettartó – tetőszerkezethez, tartós építési feladatokhoz ajánlott.' } },
    { '@type': 'Question', name: 'Mi a telített fa és mire használható?', acceptedAnswer: { '@type': 'Answer', text: 'A telített fa nagynyomáson, Tanalith védőszerrel kezelt borovi fenyő. UC4 minősítéssel 15-25 évig tartós kültéren, akár földkontaktusban is. Alkalmas kerítésekhez, cölöpöknek, játszóterekhez és kerti építményekhez.' } },
    { '@type': 'Question', name: 'Milyen tüzelőanyagokat kapok az Elvira Tüzépnél?', acceptedAnswer: { '@type': 'Answer', text: 'Keményfa brikettet (RUF bükk és Pini Kay tölgy) és fenyő pelletet (ENplus A1) kínálunk. A brikett magas fűtőértékű, alacsony hamutartalmú, a pellet pedig automatikus kazánokhoz és kandallóbetétekhez ideális.' } },
    { '@type': 'Question', name: 'Van lehetőség országos kiszállításra raklapon?', acceptedAnswer: { '@type': 'Answer', text: 'Igen! Magyarország teljes területére vállalunk raklapos kiszállítást 3-5 munkanapon belül. Pest megyébe 24-48 órán belül is szállítunk. Nagyobb tételekre egyedi árajánlatot adunk.' } },
    { '@type': 'Question', name: 'Mi a különbség a telített és a mártott fa között?', acceptedAnswer: { '@type': 'Answer', text: 'A telített fa mélyen átitatott védőszerrel (15-25 év élettartam), míg a mártott fa csak felületi védelmet kap (2-5 év). Földbe kerülő szerkezeteknél kizárólag telített fát ajánlunk.' } },
    { '@type': 'Question', name: 'Milyen fűtőértéke van a keményfa brikettnek?', acceptedAnswer: { '@type': 'Answer', text: 'A RUF bükk brikett fűtőértéke kb. 17-19 MJ/kg, a Pini Kay tölgy briketté hasonlóan magas. Ez azt jelenti, hogy 1 kg brikett kb. 3-4 kg tűzifának felel meg, minimális hamu mellett.' } },
    { '@type': 'Question', name: 'Melyik faanyag a legjobb tetőszerkezethez?', acceptedAnswer: { '@type': 'Answer', text: 'Tetőszerkezethez a műszárított, gyalult, C24 szilárdsági osztályú fenyő a legjobb. Nagyobb fesztávokhoz BSH ragasztott gerenda ajánlott, amely kiemelkedő teherbírást és mérettartást biztosít.' } },
    { '@type': 'Question', name: 'Kapható OSB lap és lambéria is az Elvira Tüzépnél?', acceptedAnswer: { '@type': 'Answer', text: 'Igen! OSB lapok 6–18 mm vastagságban (nedvességálló OSB 3), valamint prémium osztrák fenyő lambéria bel- és kültéri felhasználásra. Hajópadló és faház építő profil is elérhető készletről.' } },
  ],
};

const productsData = await fetchCategoriesOnly()
const discounted = await fetchDiscountedProducts();

const itemListJsonLd = buildSpecialOffersItemList(discounted);

