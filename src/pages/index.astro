---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero2.astro';
import Note from '~/components/widgets/Note.astro';
import Note2 from '~/components/widgets/Note2.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import SpecialOffers from '~/components/widgets/SpecialOffers.astro';
import { buildSpecialOffersItemList } from '../lib/specialOffersSchema';
import { fetchDiscountedProducts } from '~/lib/discounts';
import CategoryGrid from '../components/widgets/CategoryGrid.astro';
import MainCategoryGrid from '../components/widgets/Tabs.jsx';
import { fetchCategoriesOnly } from '../lib/medusa-adapter'
import MapWidget from '../components/widgets/MapWidget.astro';

import heroImg from '../assets/images/elvira-tuzep-hero.png';

const metadata = {
  title: 'Elvira Tüzép Érd – faanyag, brikett, telített fa',
  description: 'Fűrészáru, telített fa, BSH gerenda, brikett és pellet Érden. Gigawood Kft. telephelye. Lakossági és nagyker kiszolgálás.',
  ignoreTitleTemplate: true,
};

const schemaHome = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://elviratuzep.hu/#website",
    "name": "Elvira Tüzép",
    "url": "https://elviratuzep.hu/",
    "publisher": { "@id": "https://gigawood.hu/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://elviratuzep.hu/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://gigawood.hu/#organization",
    "name": "Gigawood Kft.",
    "url": "https://gigawood.hu/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://gigawood.hu/custom/megawood/image/cache/w220h100m00/GigaWood_logo_3_Vasvari_Design.png"
    },
    "sameAs": [
      "https://www.facebook.com/kertifajatszoter",
      "https://www.instagram.com/gigawoodkft",
      "https://www.google.com/maps?cid=4954816018312604745"
    ],
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": "+36 70 368 7809",
        "contactType": "customer service",
        "email": "info@gigawood.hu",
        "areaServed": "HU",
        "availableLanguage": ["hu"]
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://elviratuzep.hu/#store",
    "name": "Elvira Tüzép",
    "image": "https://elviratuzep.hu/images/tanalith-treating.jpg",
    "telephone": "+36 70 368 7809",
    "email": "info@elviratuzep.hu",
    "url": "https://elviratuzep.hu/",
    "priceRange": "Ft",
    "address": {
